# ============================================================
# RAG Document Intelligence — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# LLM Configuration
RAG_OPENAI_API_KEY=sk-your-openai-api-key-here
RAG_LLM_MODEL=gpt-4o
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIMENSIONS=1536

# Vector Store (ChromaDB)
RAG_CHROMA_HOST=localhost
RAG_CHROMA_PORT=8001
RAG_COLLECTION_NAME=documents

# Chunking Parameters
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

# Search Parameters
RAG_TOP_K=5
RAG_HYBRID_ALPHA=0.7

# API Settings
RAG_DEBUG=false
RAG_API_HOST=0.0.0.0
RAG_API_PORT=8000
